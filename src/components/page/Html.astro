---
import { icons } from '~/assets/images/images.icons';
import Header from './Header.astro';
import Footer from './Footer.astro';
import ThemeToggle from '~/components/base/ThemeToggle.astro';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/archivo-black/400.css';

type Props = {
  title: string;
  description: string
  jsonLd?: unknown;
  image?: string;
  themeColor?: string;
  hideHeader?: boolean;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
}

const { title, description, jsonLd, themeColor, image, hideHeader, type = 'website', publishedTime, modifiedTime, author, tags }= Astro.props;
const schema = JSON.stringify(jsonLd);
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const imageUrl = image && Astro.site ? new URL(image, Astro.site).href : image;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
    <meta http-equiv='X-UA-Compatible' content='IE=edge' />
    <meta name='HandheldFriendly' content='True' />
		<meta name="viewport" content="width=device-width" />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
		<meta name="generator" content={Astro.generator} />
    <link rel='sitemap' href='/sitemap-index.xml' />
    <link rel='manifest' href='/manifest.webmanifest' />
    <script is:inline defer src="https://umami.olsen.cloud/script.js" data-website-id="3284fd7a-6452-4048-8c8c-19740171b793" />
    {themeColor && <meta name='theme-color' content={themeColor} />}
    <link
      rel='alternate'
      type='application/rss+xml'
      title='RSS Feed'
      href='/articles/rss.xml'
    />
    <!-- Primary Meta Tags -->
    <meta name='description' content={description} />
    <link rel='canonical' href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property='og:type' content={type} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    {imageUrl && <meta property='og:image' content={imageUrl} />}
    {type === 'article' && publishedTime && (
      <meta property='article:published_time' content={publishedTime.toISOString()} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property='article:modified_time' content={modifiedTime.toISOString()} />
    )}
    {type === 'article' && author && (
      <meta property='article:author' content={author} />
    )}
    {type === 'article' && tags && tags.map(tag => (
      <meta property='article:tag' content={tag} />
    ))}

    <!-- Twitter -->
    <meta name='twitter:card' content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name='twitter:url' content={canonicalUrl} />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    {imageUrl && <meta name='twitter:image' content={imageUrl} />}

    <!-- JSON-LD Structured Data -->
    {
      jsonLd && (
        <script type='application/ld+json' is:inline set:html={schema} />
      )
    }
    {
      icons.pngs.map((icon) => (
        <link rel='icon' href={icon.src} type='image/png' sizes={icon.size} />
      ))
    }
    <title>{title}</title>
	</head>
	<body>
    <!-- Grain noise overlay -->
    <svg class="grain-overlay" aria-hidden="true">
      <filter id="grain-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.55" numOctaves="4" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#grain-filter)" />
    </svg>
    {!hideHeader && <Header />}
		<slot />
    <Footer />
    <div class="theme-toggle-fixed">
      <ThemeToggle />
    </div>
	</body>
</html>

<script is:inline>
const withFadeIn = document.querySelectorAll('[data-fadein]');

withFadeIn.forEach((node) => {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        node.classList.remove('hidden');
        node.setAttribute('data-shown', 'true')
      } else if (!node.hasAttribute('data-shown')) {
        node.classList.add('hidden');
      }
    })
  })

  observer.observe(node);
})
</script>

<style is:global>

/* ============================================================
   CASCADE ARCHITECTURE
   Layer stack declares explicit cascade priority once.
   Unlayered styles (Astro scoped components) beat all layers.
   ============================================================ */
@layer reset, tokens, layout, utilities, overrides;

/* ============================================================
   TYPED DESIGN TOKENS — @property registrations
   Type safety, animatable theme transitions, guaranteed defaults.
   ============================================================ */

/* Accent palette */
@property --accent-primary {
  syntax: "<color>";
  inherits: true;
  initial-value: #ffee00;
}
@property --accent-secondary {
  syntax: "<color>";
  inherits: true;
  initial-value: #ff5757;
}
@property --accent-tertiary {
  syntax: "<color>";
  inherits: true;
  initial-value: #00d4ff;
}
@property --accent-lime {
  syntax: "<color>";
  inherits: true;
  initial-value: #c8ff00;
}
@property --accent-lavender {
  syntax: "<color>";
  inherits: true;
  initial-value: #e4c1f9;
}

/* Surface colors */
@property --page-bg {
  syntax: "<color>";
  inherits: true;
  initial-value: #f0f0e8;
}
@property --card-bg {
  syntax: "<color>";
  inherits: true;
  initial-value: #ffffff;
}
@property --c-bg-em {
  syntax: "<color>";
  inherits: true;
  initial-value: #e8e8e0;
}

/* Text colors */
@property --t-fg {
  syntax: "<color>";
  inherits: true;
  initial-value: #000000;
}
@property --color-text-light {
  syntax: "<color>";
  inherits: true;
  initial-value: #333333;
}
@property --on-accent {
  syntax: "<color>";
  inherits: true;
  initial-value: #000000;
}

/* Border system */
@property --border-color {
  syntax: "<color>";
  inherits: true;
  initial-value: #000000;
}
@property --border-width {
  syntax: "<length>";
  inherits: true;
  initial-value: 4px;
}
@property --shadow-offset {
  syntax: "<length>";
  inherits: true;
  initial-value: 6px;
}

/* ============================================================
   RESET LAYER — normalize browser defaults
   ============================================================ */
@layer reset {
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    text-indent: 0;
    list-style-type: none;
  }

  html,
  body {
    width: 100%;
    height: 100%;
  }

  html {
    background-color: var(--page-bg);
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    font-family: var(--font-family);
    font-size: var(--fs-md);
    font-weight: var(--fw-df);
    color: var(--t-fg);
    background-color: var(--page-bg);
    overflow-x: clip;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-family-heading);
    font-weight: inherit;
    font-size: inherit;
  }

  a {
    color: var(--t-fg);
    text-decoration: none;
  }

  p {
    line-height: 1.6;
    margin-bottom: var(--gap);
  }

  p a {
    color: var(--t-fg);
    text-decoration: underline;
    text-decoration-color: var(--accent-secondary);
    text-decoration-thickness: 3px;
    text-underline-offset: 3px;
    transition: all var(--duration-fast) var(--ease-out);
    font-weight: 500;

    &:hover {
      background-color: var(--accent-secondary);
      text-decoration-color: var(--border-color);
      color: var(--on-accent);
    }
  }
}

/* ============================================================
   TOKENS LAYER — all visual properties from a single system
   ============================================================ */
@layer tokens {
  :root {
    /* Neo-brutalism core */
    --shadow-brutal: var(--shadow-offset) var(--shadow-offset) 0 var(--border-color);
    --shadow-brutal-lg: 8px 8px 0 var(--border-color);
    --radius: 0;
    --radius-sm: 0;

    /* Layout */
    --content-width: 1100px;
    --gap: 16px;

    /* Typography */
    --font-family: 'Space Grotesk', system-ui, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    --font-family-display: 'Archivo Black', 'Impact', sans-serif;
    --font-family-heading: var(--font-family-display);
    --letter-spacing: 0.5px;
    --fw-df: 400;
    --fw-md: 700;
    --fs-sm: 14px;
    --fs-md: 16px;

    /* Type scale */
    --font-xxl: 2.5rem;
    --font-xl: 1.75rem;
    --font-lg: 1.25rem;
    --font-sm: 0.875rem;
    --font-xs: 0.75rem;

    /* Spacing scale */
    --space-xs: 0.25rem;
    --space-sm: 0.5rem;
    --space-md: 1rem;
    --space-lg: 2rem;
    --space-xl: 3rem;
    --space-xxl: 4rem;

    /* Motion tokens — centralized, respects user preference */
    --duration-fast: 0.1s;
    --duration-normal: 0.3s;
    --duration-slow: 0.5s;
    --duration-glacial: 1s;
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);

    /* Link colors */
    --color-link: #000;
  }

  /* Reduced motion: zero all durations globally */
  @media (prefers-reduced-motion: reduce) {
    :root {
      --duration-fast: 0s;
      --duration-normal: 0s;
      --duration-slow: 0s;
      --duration-glacial: 0s;
    }
  }

  /* Dark mode — cascades via DOM attribute, no JS runtime needed */
  [data-theme="dark"] {
    --page-bg: #111118;
    --card-bg: #1c1c26;
    --t-fg: #f0f0e8;
    --border-color: #f0f0e8;
    --shadow-brutal: var(--shadow-offset) var(--shadow-offset) 0 #0a0a10;
    --shadow-brutal-lg: 8px 8px 0 #0a0a10;
    --c-bg-em: #26263a;
    --color-text-light: #a0a0a8;
    --color-link: #f0f0e8;

    /* Boosted accents for dark mode — more neon/vivid */
    --accent-primary: #ffe600;
    --accent-secondary: #ff4d4d;
    --accent-tertiary: #00e5ff;
    --accent-lime: #d4ff00;
    --accent-lavender: #d8b4fe;

    /* Text on accent backgrounds stays dark in both themes */
    --on-accent: #000;
  }

  /* Smooth theme transition on registered color properties */
  html {
    transition:
      --page-bg var(--duration-normal) var(--ease-out),
      --card-bg var(--duration-normal) var(--ease-out),
      --t-fg var(--duration-normal) var(--ease-out),
      --border-color var(--duration-normal) var(--ease-out),
      --c-bg-em var(--duration-normal) var(--ease-out),
      --color-text-light var(--duration-normal) var(--ease-out);
  }

  /* Accent backgrounds: any element with [data-accent-bg] gets
     dark text/borders automatically — no per-class overrides needed */
  [data-accent-bg] {
    color: var(--on-accent);
  }
}

/* ============================================================
   LAYOUT LAYER — page-level structure
   ============================================================ */
@layer layout {
  [data-fadein] {
    transition: all var(--duration-glacial);
  }

  .hidden {
    opacity: 0;
  }

  .grain-overlay {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.35;
    mix-blend-mode: multiply;
  }

  [data-theme="dark"] .grain-overlay {
    opacity: 0.15;
    mix-blend-mode: screen;
  }

  .theme-toggle-fixed {
    position: fixed;
    bottom: var(--gap);
    right: var(--gap);
    z-index: 1000;
  }
}

/* ============================================================
   UTILITIES LAYER — thin composition helpers for gaps only
   ============================================================ */
@layer utilities {
  .brutal-border {
    border: var(--border-width) solid var(--border-color);
  }

  .brutal-shadow {
    box-shadow: var(--shadow-brutal);
    transition: box-shadow var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);

    &:hover {
      box-shadow: calc(var(--shadow-offset) + 2px) calc(var(--shadow-offset) + 2px) 0 var(--border-color);
      transform: translate(-2px, -2px);
    }
  }
}

/* ============================================================
   OVERRIDES LAYER — view transitions, print, escape hatches
   ============================================================ */
@layer overrides {
  @view-transition {
    navigation: auto;
  }

  ::view-transition-old(root) {
    animation: brutal-wipe-out var(--duration-normal) ease-in both;
  }

  ::view-transition-new(root) {
    animation: brutal-wipe-in var(--duration-normal) ease-out 0.15s both;
  }

  @keyframes brutal-wipe-out {
    from {
      clip-path: inset(0);
      opacity: 1;
    }
    to {
      clip-path: inset(0 0 0 100%);
      opacity: 0.5;
    }
  }

  @keyframes brutal-wipe-in {
    from {
      clip-path: inset(0 100% 0 0);
      opacity: 0.5;
    }
    to {
      clip-path: inset(0);
      opacity: 1;
    }
  }

  @media print {
    @page {
      size: A4;
      margin: 2cm 1.5cm;
    }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 11pt;
      line-height: 1.4;
      color: #000;
    }

    header.header {
      display: none !important;
    }

    a {
      text-decoration: none;
      color: #000;
    }

    .brutal-shadow {
      box-shadow: none;
    }

    .brutal-border {
      border-width: 1px;
    }

    [data-fadein] {
      opacity: 1 !important;
    }

    .theme-toggle-fixed {
      display: none !important;
    }
  }
}

</style>
