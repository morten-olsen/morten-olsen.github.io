.subtitle { animation: slideUpBounce 0.4s var(--ease-out) 0.75s both; }
.tagline { animation: slideUpBounce 0.4s var(--ease-out) 0.85s both; }
.terminal { animation: slideUpBounce 0.5s var(--ease-out) 0.95s both; }
.cta-row { animation: slideUpBounce 0.4s var(--ease-out) 1.1s both; }

.sticker-star-1 { animation: spinIn 0.5s var(--ease-bounce) 0.7s both, wobble 5s ease-in-out infinite 1.2s; }
.sticker-star-2 { animation: spinIn 0.5s var(--ease-bounce) 0.85s both, wobble 4s ease-in-out infinite 1.35s; }
.sticker-heart { animation: spinIn 0.5s var(--ease-bounce) 1s both, wobble 6s ease-in-out infinite 1.5s; }

