/* ============================================================
   ENTRY ANIMATIONS — staggered theatrical reveal
   ============================================================ */
@keyframes wipeReveal {
  from { clip-path: inset(0 100% 0 0); opacity: 0; }
  to { clip-path: inset(0 0 0 0); opacity: 1; }
}

@keyframes slideUpBounce {
  0% { opacity: 0; transform: translateY(28px); }
  60% { opacity: 1; transform: translateY(-3px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes dropIn {
  0% { opacity: 0; transform: translateY(-30px) rotate(-8deg); }
  60% { opacity: 1; transform: translateY(4px) rotate(-1deg); }
  100% { opacity: 1; transform: translateY(0) rotate(-3deg); }
}

@keyframes spinIn {
  from { opacity: 0; transform: scale(0) rotate(180deg); }
  to { opacity: 1; transform: scale(1) rotate(0deg); }
}

.browser { animation: slideUpBounce 0.6s var(--ease-out) 0.1s both; }
.polaroid { animation: dropIn 0.6s var(--ease-bounce) 0.4s both; }
.status-box { animation: slideUpBounce 0.5s var(--ease-out) 0.55s both; }
