---
import { Picture } from "astro:assets";
import AbsoluteTime from "~/components/base/time/AbsoluteTime.astro";
import Html from "~/components/page/Html.astro";
import { data } from "~/data/data"

const { Content, ...profile } = data.profile;
const posts = await data.posts.getPublished();
const currentExperience = await data.experiences.getCurrent();
const jsonLd = await profile.getJsonLd();
---

<Html
  title={profile.name}
  description={profile.name}
  jsonLd={jsonLd}
  hideHeader
>
  <section class="hero" aria-label="Welcome">
    <!-- Fake browser-window chrome wrapping the hero -->
    <div class="browser">
      <div class="browser-titlebar">
        <div class="browser-dots" aria-hidden="true">
          <span class="dot dot-red"></span>
          <span class="dot dot-amber"></span>
          <span class="dot dot-green"></span>
        </div>
        <div class="browser-url">
          <span class="lock" aria-hidden="true">⚿</span>
          <span class="url-prefix">http://</span>morten.local/~me/<span class="url-cursor">_</span>
        </div>
        <div class="browser-meta" aria-hidden="true">
          <span>1024 × 768</span>
        </div>
      </div>

      <div class="browser-stage">
        <!-- floating decorations: stickers, blinkies, sparkles -->
        <div class="sticker sticker-star-1" aria-hidden="true">
          <svg viewBox="0 0 100 100"><polygon points="50,5 61,38 96,38 67,58 78,92 50,72 22,92 33,58 4,38 39,38" fill="currentColor" stroke="var(--border-color)" stroke-width="3"/></svg>
        </div>
        <div class="sticker sticker-star-2" aria-hidden="true">
          <svg viewBox="0 0 100 100"><polygon points="50,5 61,38 96,38 67,58 78,92 50,72 22,92 33,58 4,38 39,38" fill="currentColor" stroke="var(--border-color)" stroke-width="3"/></svg>
        </div>
        <div class="sticker sticker-heart" aria-hidden="true">
          <svg viewBox="0 0 100 100"><path d="M50 88 L12 52 C2 42 2 24 12 14 C22 4 38 4 48 14 L50 16 L52 14 C62 4 78 4 88 14 C98 24 98 42 88 52 Z" fill="currentColor" stroke="var(--border-color)" stroke-width="3"/></svg>
        </div>
        <div class="sticker sticker-sparkle-1" aria-hidden="true">✦</div>
        <div class="sticker sticker-sparkle-2" aria-hidden="true">✦</div>
        <div class="sticker sticker-sparkle-3" aria-hidden="true">✧</div>
        <div class="sticker sticker-arrow" aria-hidden="true">↘</div>

        <div class="browser-grid">
          <!-- Left column: polaroid + status badges -->
          <div class="left-stack">
            <div class="polaroid">
              <div class="washi tape-1" aria-hidden="true"></div>
              <div class="washi tape-2" aria-hidden="true"></div>
              <Picture
                alt='Profile picture'
                src={profile.image}
                formats={['avif', 'webp', 'jpeg']}
                fetchpriority="high"
                widths={[300, 400, 500]}
              />
              <div class="polaroid-caption">~me, smiling at a deploy</div>
            </div>

            <!-- "Currently:" status box -->
            <aside class="status-box">
              <div class="status-box-head">currently.txt</div>
              <ul>
                <li><b>📍</b> {profile.location.city}</li>
                {currentExperience && (
                  <li><b>💼</b> {currentExperience.data.position.name}</li>
                )}
                <li><b>🎧</b> compiler humming</li>
                <li><b>☕</b> at least 3 deep</li>
              </ul>
            </aside>
          </div>

          <!-- Right column: title block + terminal + CTA -->
          <div class="right-stack">
            <div class="title-block">
              <div class="hello">
                <span class="hello-tag">&lt;hello&gt;</span>
              </div>
              <h1 class="hero-title">
                <span class="title-line line-1">MORTEN</span>
                <span class="title-line line-2">OLSEN</span>
              </h1>
              <p class="subtitle">
                <span class="role-prefix">role=</span>"Software Engineer"
                <span class="role-tag" aria-hidden="true">⌘</span>
              </p>
              <p class="tagline">
                I make computers do questionable things —
                <em>sometimes on purpose</em>.
              </p>
            </div>

            <!-- Tongue-in-cheek "now compiling" terminal widget -->
            <div class="terminal" role="presentation">
              <div class="terminal-head">
                <span class="terminal-dot td-r"></span>
                <span class="terminal-dot td-a"></span>
                <span class="terminal-dot td-g"></span>
                <span class="terminal-title">/usr/local/bin/morten</span>
              </div>
              <div class="terminal-body">
                <div class="line"><span class="prompt">$</span> ./status --human</div>
                <div class="line"><span class="ok">[OK]</span> coffee.service running</div>
                <div class="line"><span class="ok">[OK]</span> git fetch --all</div>
                <div class="line"><span class="warn">[..]</span> compiling something useless<span class="dots">...</span></div>
                <div class="progress" aria-hidden="true">
                  <div class="progress-fill"></div>
                  <div class="progress-text">47% — eta: never</div>
                </div>
                <div class="line"><span class="prompt">$</span> <span class="cursor-blink">▮</span></div>
              </div>
            </div>

            <div class="cta-row">
              <a href="/about/" class="cta cta-primary">
                <span aria-hidden="true">→</span> open /about/
              </a>
              <a href="#writing" class="cta cta-secondary">
                <span aria-hidden="true">▾</span> scroll to writing
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Browser status bar -->
      <div class="browser-statusbar" aria-hidden="true">
        <span class="sb-left">Done.</span>
        <span class="sb-mid">Transferred 13.37 KB · 0 errors · 1 warning (vibe)</span>
        <span class="sb-right">100%</span>
      </div>
    </div>
  </section>

  <!-- Marquee — restyled as a classic <marquee> tape -->
  <div class="marquee" aria-hidden="true">
    <span class="marquee-arrow left">◂</span>
    <div class="marquee-window">
      <div class="marquee-track">
        <span>★ FRONTEND</span>
        <span>★ BACKEND</span>
        <span>★ DEVOPS</span>
        <span>★ COPENHAGEN</span>
        <span>★ TYPESCRIPT</span>
        <span>★ REACT</span>
        <span>★ KUBERNETES</span>
        <span>★ NODE.JS</span>
        <span>★ POSTGRES</span>
        <span>★ FRONTEND</span>
        <span>★ BACKEND</span>
        <span>★ DEVOPS</span>
        <span>★ COPENHAGEN</span>
        <span>★ TYPESCRIPT</span>
        <span>★ REACT</span>
        <span>★ KUBERNETES</span>
        <span>★ NODE.JS</span>
        <span>★ POSTGRES</span>
      </div>
    </div>
    <span class="marquee-arrow right">▸</span>
  </div>

  <main class="main">
    <section class="posts-section" id="writing">
      <header class="posts-header">
        <h2 class="section-title" data-fadein>
          <span class="folder-tab">▾ writing/</span>
        </h2>
        <p class="section-sub" data-fadein>
          <span class="comment">// notes from the keyboard. {posts.length} entries.</span>
        </p>
      </header>

      <div class="posts">
        {posts.map((post, index) => {
          const isFeatured = index === 0;
          const isWide = index >= 3 && (index - 3) % 4 === 0;
          return (
            <article
              class:list={['post', { featured: isFeatured, wide: isWide }]}
              data-fadein
              style={`--delay: ${index * 0.06}s`}
            >
              <a href={`/posts/${post.id}`} class="post-link">
                <div class="post-tape" aria-hidden="true"></div>
                <div class="post-image">
                  <Picture
                    alt='thumbnail image'
                    src={post.data.heroImage}
                    formats={['avif', 'webp', 'jpeg']}
                    fetchpriority='auto'
                    widths={[200, 400, 600]}
                  />
                </div>
                <div class="post-content">
                  <h3>{post.data.title}</h3>
                  <p class="post-description">{post.data.description}</p>
                  <div class="post-meta">
                    <span class="meta-icon" aria-hidden="true">📅</span>
                    <AbsoluteTime
                      datetime={post.data.pubDate}
                      format={{ month: "short", year: "numeric" }}
                    />
                    <span class="meta-sep" aria-hidden="true">·</span>
                    <span class="meta-icon" aria-hidden="true">⏱</span>
                    {post.readingTime} min
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </section>
  </main>
</Html>

<script src="../scripts/fadein.ts"></script>

<style>
/* ============================================================
   HERO — fake "browser window" full-bleed
   ============================================================ */
.hero {
  padding: calc(var(--gap) * 1.5) calc(var(--gap) * 1.5) calc(var(--gap) * 2);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.browser {
  width: 100%;
  max-width: 1100px;
  background: var(--card-bg);
  border: var(--border-width) solid var(--border-color);
  box-shadow: 8px 8px 0 var(--border-color);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* Title bar */
.browser-titlebar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 12px;
  background: linear-gradient(180deg, var(--accent-tertiary), color-mix(in srgb, var(--accent-tertiary) 80%, var(--border-color)));
  border-bottom: 2px solid var(--border-color);
  font-family: var(--font-family-mono);
  color: var(--on-accent);
}

.browser-dots {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
}

.dot {
  width: 13px;
  height: 13px;
  border: 2px solid var(--border-color);
  display: inline-block;
}

.dot-red { background: #ff5f56; }
.dot-amber { background: #ffbd2e; }
.dot-green { background: #27c93f; }

.browser-url {
  flex: 1;
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  padding: 4px 10px;
  font-size: 17px;
  color: var(--t-fg);
  display: flex;
  align-items: center;
  gap: 6px;
  letter-spacing: 0.4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.lock {
  color: var(--accent-secondary);
}

.url-prefix {
  color: var(--color-text-light);
}

.url-cursor {
  color: var(--accent-secondary);
  font-weight: 700;
  animation: blink-cursor 1s steps(2, jump-none) infinite;
}

@keyframes blink-cursor {
  50% { opacity: 0; }
}

.browser-meta {
  font-size: 14px;
  flex-shrink: 0;
  letter-spacing: 0.5px;
  opacity: 0.85;
}

/* Stage — content area */
.browser-stage {
  position: relative;
  padding: calc(var(--gap) * 2.5) calc(var(--gap) * 2);
  background:
    radial-gradient(circle at 25% 18%, color-mix(in srgb, var(--accent-primary) 35%, transparent) 0, transparent 38%),
    radial-gradient(circle at 80% 80%, color-mix(in srgb, var(--accent-tertiary) 25%, transparent) 0, transparent 42%),
    var(--card-bg);
  overflow: hidden;
  min-height: 540px;
}

/* Floating stickers */
.sticker {
  position: absolute;
  z-index: 1;
  pointer-events: none;
  filter: drop-shadow(2px 2px 0 var(--border-color));
}

.sticker-star-1 {
  width: 64px;
  height: 64px;
  top: 6%;
  right: 8%;
  color: var(--accent-secondary);
  rotate: 12deg;
  animation: wobble 5s ease-in-out infinite;
}

.sticker-star-2 {
  width: 38px;
  height: 38px;
  bottom: 12%;
  left: 6%;
  color: var(--accent-primary);
  rotate: -18deg;
  animation: wobble 4s ease-in-out infinite -1s;
}

.sticker-heart {
  width: 46px;
  height: 46px;
  top: 38%;
  right: 4%;
  color: var(--accent-lime);
  rotate: -8deg;
  animation: wobble 6s ease-in-out infinite -2s;
}

.sticker-sparkle-1,
.sticker-sparkle-2,
.sticker-sparkle-3 {
  font-family: var(--font-family-display);
  font-size: 28px;
  color: var(--accent-secondary);
  filter: none;
  text-shadow: 1px 1px 0 var(--border-color);
}

.sticker-sparkle-1 {
  top: 22%;
  left: 4%;
  animation: blink-anim 2.4s steps(2, jump-none) infinite;
}

.sticker-sparkle-2 {
  bottom: 28%;
  right: 22%;
  font-size: 22px;
  color: var(--accent-tertiary);
  animation: blink-anim 1.8s steps(2, jump-none) infinite -0.6s;
}

.sticker-sparkle-3 {
  top: 56%;
  left: 18%;
  font-size: 18px;
  color: var(--accent-primary);
  animation: blink-anim 2.1s steps(2, jump-none) infinite -1.1s;
}

.sticker-arrow {
  font-family: var(--font-family-mono);
  font-size: 32px;
  color: var(--accent-secondary);
  bottom: 6%;
  right: 10%;
  rotate: 10deg;
  filter: none;
  text-shadow: 2px 2px 0 var(--border-color);
}

@keyframes wobble {
  0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
  50% { transform: translateY(-6px) rotate(calc(var(--r, 0deg) + 3deg)); }
}

@keyframes blink-anim {
  50% { opacity: 0.15; }
}

/* Browser grid layout */
.browser-grid {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: minmax(220px, 280px) 1fr;
  gap: calc(var(--gap) * 2);
  align-items: start;
}

/* ---- Left column: polaroid + status ---------------------- */
.left-stack {
  display: flex;
  flex-direction: column;
  gap: calc(var(--gap) * 1.25);
}

.polaroid {
  position: relative;
  background: #fff;
  padding: 10px 10px 36px;
  border: 2px solid var(--border-color);
  box-shadow: 5px 5px 0 var(--border-color);
  rotate: -3deg;
  transition: rotate var(--duration-normal) var(--ease-out);

  &:hover {
    rotate: 0deg;
  }

  img {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.05);
  }
}

[data-theme="dark"] .polaroid {
  background: #f4ecd8;
}

.polaroid-caption {
  position: absolute;
  bottom: 6px;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 16px;
  color: #1a1814;
  font-family: var(--font-family-mono);
  font-style: italic;
}

/* Washi tape */
.washi {
  position: absolute;
  width: 70px;
  height: 22px;
  background: var(--accent-primary);
  border: 1px dashed var(--border-color);
  opacity: 0.85;
  z-index: 2;
}

.tape-1 {
  top: -10px;
  left: -16px;
  rotate: -22deg;
  background: repeating-linear-gradient(
    45deg,
    var(--accent-primary) 0 8px,
    color-mix(in srgb, var(--accent-primary) 70%, var(--border-color)) 8px 14px
  );
}

.tape-2 {
  top: -8px;
  right: -12px;
  rotate: 18deg;
  background: repeating-linear-gradient(
    45deg,
    var(--accent-tertiary) 0 8px,
    color-mix(in srgb, var(--accent-tertiary) 70%, var(--border-color)) 8px 14px
  );
}

/* Status box */
.status-box {
  border: 2px solid var(--border-color);
  background: var(--c-bg-em);
  box-shadow: 4px 4px 0 var(--border-color);
  font-family: var(--font-family-mono);
  rotate: 1.5deg;
  transition: rotate var(--duration-normal) var(--ease-out);

  &:hover { rotate: 0deg; }
}

.status-box-head {
  background: var(--border-color);
  color: var(--page-bg);
  padding: 4px 10px;
  font-size: 16px;
  letter-spacing: 0.5px;
}

.status-box ul {
  padding: 10px 12px;
  font-size: 17px;
  line-height: 1.5;

  li {
    display: flex;
    align-items: center;
    gap: 10px;

    b { font-style: normal; }
  }
}

/* ---- Right column: title + terminal + CTAs --------------- */
.right-stack {
  display: flex;
  flex-direction: column;
  gap: calc(var(--gap) * 1.5);
  min-width: 0;
}

.title-block {
  position: relative;
}

.hello {
  font-family: var(--font-family-mono);
  font-size: 17px;
  color: var(--accent-secondary);
  margin-bottom: calc(var(--gap) / 2);
  letter-spacing: 0.5px;
}

.hero-title {
  font-family: var(--font-family-display);
  font-weight: 700;
  font-size: clamp(3rem, 8.5vw, 6rem);
  line-height: 0.9;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  margin-bottom: calc(var(--gap));
  display: flex;
  flex-direction: column;
  position: relative;
}

.title-line {
  display: inline-block;
  position: relative;

  &.line-1 {
    color: var(--t-fg);
    text-shadow:
      3px 0 var(--accent-secondary),
      6px 0 var(--accent-tertiary);
  }

  &.line-2 {
    color: var(--t-fg);
    text-shadow:
      -3px 0 var(--accent-primary),
      -6px 0 var(--accent-lavender);
    margin-left: 1.5rem;
  }
}

.subtitle {
  font-family: var(--font-family-mono);
  font-size: clamp(1rem, 2.2vw, 1.25rem);
  color: var(--t-fg);
  margin-bottom: calc(var(--gap) * 0.75);
  display: flex;
  align-items: baseline;
  gap: 8px;

  .role-prefix {
    color: var(--accent-secondary);
  }

  .role-tag {
    color: var(--accent-tertiary);
    font-size: 1.2em;
    margin-left: auto;
    animation: spin-slow 8s linear infinite;
    transform-origin: center;
    display: inline-block;
  }
}

@keyframes spin-slow {
  to { transform: rotate(360deg); }
}

.tagline {
  font-family: var(--font-family-mono);
  font-size: clamp(1.05rem, 1.9vw, 1.25rem);
  color: var(--color-text-light);
  line-height: 1.45;
  max-width: 46ch;
  margin: 0;
  padding: 6px 0 6px 14px;
  border-left: 3px solid var(--accent-tertiary);

  &::before {
    content: '/* ';
    color: var(--accent-secondary);
    font-weight: 700;
  }

  &::after {
    content: ' */';
    color: var(--accent-secondary);
    font-weight: 700;
  }

  em {
    color: var(--accent-secondary);
    font-weight: 700;
    font-style: italic;
  }
}

/* Terminal widget */
.terminal {
  border: 2px solid var(--border-color);
  background: #0a0e1a;
  box-shadow: 5px 5px 0 var(--border-color);
  overflow: hidden;
  font-family: var(--font-family-mono);
  rotate: -1deg;
  transition: rotate var(--duration-normal) var(--ease-out);

  &:hover { rotate: 0deg; }
}

[data-theme="dark"] .terminal {
  background: #02050a;
}

.terminal-head {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  background: linear-gradient(180deg, #2a2d3a, #1a1d2a);
  border-bottom: 1px solid #3a3d4a;
}

.terminal-dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  display: inline-block;
}

.td-r { background: #ff5f56; }
.td-a { background: #ffbd2e; }
.td-g { background: #27c93f; }

.terminal-title {
  font-size: 14px;
  color: #8a8d9a;
  margin-left: 8px;
  letter-spacing: 0.5px;
}

.terminal-body {
  padding: 14px 16px;
  font-size: 18px;
  line-height: 1.45;
  color: #e0e4f0;

  .line {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .prompt {
    color: var(--accent-secondary);
    font-weight: 700;
    margin-right: 6px;
  }

  .ok {
    color: #39ff14;
    margin-right: 6px;
  }

  .warn {
    color: #ffbd2e;
    margin-right: 6px;
    animation: blink-anim 1s steps(2, jump-none) infinite;
  }

  .dots::after {
    content: '';
    animation: ellipsis 1.4s steps(4, jump-none) infinite;
  }

  .cursor-blink {
    color: var(--accent-blink);
    animation: blink-cursor 1s steps(2, jump-none) infinite;
  }
}

@keyframes ellipsis {
  0% { content: ''; }
  25% { content: '.'; }
  50% { content: '..'; }
  75% { content: '...'; }
}

.progress {
  position: relative;
  margin: 6px 0 6px 28px;
  height: 18px;
  background: #1a1d2a;
  border: 1px solid #3a3d4a;
  overflow: hidden;
}

.progress-fill {
  position: absolute;
  inset: 0 53% 0 0;
  background: repeating-linear-gradient(
    90deg,
    var(--accent-blink) 0 10px,
    color-mix(in srgb, var(--accent-blink) 60%, #000) 10px 16px
  );
  animation: progress-pulse 2s ease-in-out infinite;
}

.progress-text {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: #fff;
  text-shadow: 1px 1px 0 #000;
  letter-spacing: 0.5px;
}

@keyframes progress-pulse {
  0%, 100% { inset: 0 60% 0 0; }
  50% { inset: 0 35% 0 0; }
}

/* CTAs */
.cta-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.cta {
  padding: 10px 18px;
  border: 2px solid var(--border-color);
  font-family: var(--font-family-mono);
  font-size: 18px;
  letter-spacing: 0.4px;
  box-shadow: 4px 4px 0 var(--border-color);
  transition: all var(--duration-fast) var(--ease-out);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  line-height: 1;
}

.cta-primary {
  background: var(--accent-primary);
  color: var(--on-accent);

  &:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--border-color);
    background: var(--accent-secondary);
  }
}

.cta-secondary {
  background: var(--card-bg);
  color: var(--t-fg);

  &:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--border-color);
    background: var(--accent-lavender);
    color: var(--on-accent);
  }
}

/* Browser status bar */
.browser-statusbar {
